# Strava API credentials (required)
STRAVA_CLIENT_ID=your_client_id
STRAVA_CLIENT_SECRET=your_client_secret

# Notification channel: discord, slack, or telegram
NOTIFICATION_CHANNEL=telegram

# Discord (if using discord)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Slack (if using slack)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Telegram (if using telegram)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_CHAT_ID=your_chat_id

# Training thresholds (optional - sensible defaults)
MAX_HEART_RATE=201
VT1_HEART_RATE=175
MAX_WEEKLY_MILEAGE_JUMP=30
MAX_HARD_DAY_PERCENTAGE=25
PLANNED_REST_DAYS=2

# Debug logging
VERBOSE=false
