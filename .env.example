# Strava API credentials (required)
STRAVA_CLIENT_ID=your_client_id
STRAVA_CLIENT_SECRET=your_client_secret

# HR thresholds — DEPRECATED: use athlete_config.py instead
# These env vars still work as fallback if athlete_config.json doesn't exist
# MAX_HEART_RATE=201
# VT1_HEART_RATE=175

# Training thresholds (optional - sensible defaults)
MAX_WEEKLY_MILEAGE_JUMP=30      # 5-100%, default: 30
MAX_HARD_DAY_PERCENTAGE=25      # 5-100%, default: 25
PLANNED_REST_DAYS=2             # 0-7, default: 2

# Debug logging
VERBOSE=false
